{
  "name": "btp-cap-sc2-location-app",
  "version": "1.0.0",
  "description": "CAP app: S/4HANA location search + Service Cloud V2 case extension field update",
  "private": true,
  "license": "UNLICENSED",
  "dependencies": {
    "@sap/cds": "^9.0.0",
    "@cap-js/sqlite": "^1.6.0",
    "@sap/xssec": "^4.0.0",
    "@sap-cloud-sdk/resilience": "^3.0.0",
    "@sap-cloud-sdk/connectivity": "^3.0.0",
    "@sap-cloud-sdk/http-client": "^3.0.0",
    "passport": "^0.7.0",
    "axios": "^1.7.2",
    "express": "^4.18.3"
  },
  "devDependencies": {
    "@sap/cds-dk": "^9.0.0"
  },
  "scripts": {
    "start": "cds-serve",
    "dev": "cds watch",
    "build": "cds build --production"
  },
  "cds": {
    "requires": {
      "SC2_DESTINATION": {
        "kind": "rest",
        "credentials": {
          "destination": "Case_Object"
        }
      },
      "db": {
        "kind": "sqlite",
        "[production]": { "credentials": { "url": ":memory:" } }
      },
      "[production]": {
        "auth": {
          "kind": "dummy"
        }
      }
    }
  },
  "engines": { "node": ">=20" }
}
