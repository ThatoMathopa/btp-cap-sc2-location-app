<mvc:View
  controllerName="com.company.locationmashup.controller.LocationMashup"
  xmlns:mvc="sap.ui.core.mvc"
  xmlns="sap.m"
  xmlns:l="sap.ui.layout"
  xmlns:core="sap.ui.core"
  xmlns:html="http://www.w3.org/1999/xhtml"
  displayBlock="true">

  <Page id="mashupPage" showHeader="false" enableScrolling="true">
    <content>
      <VBox>

        <!-- City of Tshwane Header -->
        <HBox
          alignItems="Center"
          justifyContent="SpaceBetween"
          class="sapUiTinyMarginBegin sapUiTinyMarginEnd sapUiTinyMarginTop sapUiTinyMarginBottom">
          <HBox alignItems="Center">
            <!-- CoT logo badge (CSS — no external image dependency) -->
            <html:div style="width:40px;height:40px;background:#1a5276;border-radius:50%;display:flex;align-items:center;justify-content:center;margin-right:10px;flex-shrink:0;">
              <html:span style="color:#fff;font-weight:700;font-size:0.75rem;letter-spacing:0.05em;line-height:1;">CoT</html:span>
            </html:div>
            <VBox>
              <Title text="GIS Location Search" level="H4" titleStyle="H4" />
              <Label text="City of Tshwane Metropolitan Municipality" />
            </VBox>
          </HBox>
          <HBox alignItems="Center" visible="{= !!${state>/caseId} }">
            <html:div style="background:#1a5276;color:#fff;padding:4px 10px;border-radius:4px;font-size:0.8rem;display:flex;align-items:center;gap:6px;">
              <core:Icon src="sap-icon://crm-service-manager" color="#fff" size="0.875rem" />
              <html:span style="opacity:0.8;">Case:</html:span>
              <html:span style="font-weight:600;"><Text text="{state>/caseId}" /></html:span>
            </html:div>
          </HBox>
        </HBox>

        <!-- Tshwane accent bar -->
        <html:div style="height:3px;background:linear-gradient(90deg,#1a5276 0%,#2e86c1 40%,#27ae60 70%,#f39c12 100%);" />

        <!-- Status message -->
        <MessageStrip
          id="statusStrip"
          text="{state>/statusMessage}"
          type="{state>/statusState}"
          showIcon="true"
          showCloseButton="true"
          visible="{= !!${state>/statusMessage} }"
          close=".onClearStatus"
          class="sapUiTinyMarginBegin sapUiTinyMarginEnd sapUiTinyMarginTop" />

        <!-- Missing case ID warning -->
        <MessageStrip
          text="No Case ID provided. Open this app from a Service Cloud case to enable location updates."
          type="Warning"
          showIcon="true"
          visible="{= !${state>/caseId} }"
          class="sapUiTinyMarginBegin sapUiTinyMarginEnd sapUiTinyMarginTop" />

        <!-- Search and Filter Panel -->
        <Panel
          expandable="true"
          expanded="true"
          class="sapUiTinyMarginBegin sapUiTinyMarginEnd sapUiTinyMarginTop">
          <headerToolbar>
            <Toolbar height="2.5rem">
              <Title text="Search and Filter" level="H5" />
              <ToolbarSpacer />
              <Button
                text="Reset"
                icon="sap-icon://clear-filter"
                press=".onReset"
                type="Transparent" />
              <Button
                icon="sap-icon://synchronize"
                press=".onSync"
                type="Transparent"
                tooltip="Sync from S/4HANA" />
            </Toolbar>
          </headerToolbar>
          <content>
            <l:Grid defaultSpan="XL4 L4 M6 S12" class="sapUiTinyMarginTop">
              <l:content>
                <VBox>
                  <Label text="Search" design="Bold" labelFor="globalSearch" />
                  <SearchField
                    id="globalSearch"
                    placeholder="Name, ward, region..."
                    liveChange=".onLiveSearch"
                    search=".onLiveSearch"
                    showRefreshButton="false"
                    width="100%" />
                </VBox>
                <VBox>
                  <Label text="Ward" design="Bold" labelFor="filterWard" />
                  <Select id="filterWard" change=".onLiveSearch" width="100%" forceSelection="false">
                    <core:Item key="" text="All Wards" />
                  </Select>
                </VBox>
                <VBox>
                  <Label text="Region" design="Bold" labelFor="filterRegion" />
                  <Select id="filterRegion" change=".onLiveSearch" width="100%" forceSelection="false">
                    <core:Item key="" text="All Regions" />
                  </Select>
                </VBox>
              </l:content>
            </l:Grid>
          </content>
        </Panel>

        <!-- Locations table -->
        <Table
          id="locationsTable"
          items="{results>/results}"
          busy="{results>/busy}"
          growing="true"
          growingThreshold="20"
          growingScrollToLoad="true"
          mode="SingleSelectMaster"
          noDataText="No locations found."
          sticky="ColumnHeaders"
          class="sapUiTinyMarginBegin sapUiTinyMarginEnd"
          alternateRowColors="true">

          <headerToolbar>
            <Toolbar height="2.5rem">
              <core:Icon src="sap-icon://map" color="#1a5276" class="sapUiTinyMarginEnd" />
              <Title text="Location Results" level="H5" />
              <ToolbarSpacer />
              <Text id="resultCount" text="Loading locations..." class="sapUiTinyMarginEnd" />
            </Toolbar>
          </headerToolbar>

          <columns>
            <Column width="35%">
              <Label text="Location Name" design="Bold" />
            </Column>
            <Column width="15%" minScreenWidth="Tablet" demandPopin="true" hAlign="Center">
              <Label text="Ward" design="Bold" />
            </Column>
            <Column width="20%" minScreenWidth="Tablet" demandPopin="true" hAlign="Center">
              <Label text="Region" design="Bold" />
            </Column>
            <Column width="10%" minScreenWidth="Desktop" demandPopin="true" hAlign="Center">
              <Label text="Extension" design="Bold" />
            </Column>
            <Column width="20%" hAlign="End">
              <Label text="Action" design="Bold" />
            </Column>
          </columns>

          <items>
            <ColumnListItem type="Active" press=".onRowPress">
              <cells>
                <ObjectIdentifier
                  title="{results>LocationName}"
                  text="{= ${results>Extension} &amp;&amp; ${results>Extension} !== '0' ? 'Ext: ' + ${results>Extension} : '' }" />
                <ObjectStatus text="{results>Ward}" state="Information" inverted="true" />
                <ObjectStatus text="{results>Region}" state="Success" />
                <Text text="{= ${results>Extension} === '0' ? '' : ${results>Extension} }" />
                <Button
                  text="Select"
                  type="Emphasized"
                  icon="sap-icon://accept"
                  press=".onUseLocation"
                  enabled="{= !!${state>/caseId} }"
                  tooltip="{= !${state>/caseId} ? 'Open from SC2 case to enable' : 'Assign this location to the case' }" />
              </cells>
            </ColumnListItem>
          </items>
        </Table>

        <!-- Footer -->
        <html:div style="text-align:center;padding:8px;color:#95a5a6;font-size:0.7rem;border-top:1px solid #ecf0f1;margin:8px 0 0 0;">
          City of Tshwane Metropolitan Municipality — Powered by SAP BTP
        </html:div>

      </VBox>
    </content>
  </Page>
</mvc:View>
