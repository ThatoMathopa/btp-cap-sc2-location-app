<mvc:View
  controllerName="com.company.locationmashup.controller.LocationMashup"
  xmlns:mvc="sap.ui.core.mvc"
  xmlns="sap.m"
  xmlns:l="sap.ui.layout"
  xmlns:core="sap.ui.core"
  displayBlock="true">

  <Page id="mashupPage" showHeader="false">
    <content>
      <VBox class="sapUiSmallMargin" fitContainer="true">

        <!-- ═══ Header bar ══════════════════════════════════════════════ -->
        <HBox alignItems="Center" class="sapUiSmallMarginBottom">
          <core:Icon src="sap-icon://map" color="#0070F2" size="1.5rem" class="sapUiSmallMarginEnd" />
          <Title text="{i18n>appTitle}" level="H3" />
          <ToolbarSpacer />
          <HBox alignItems="Center" visible="{= !!${state>/caseId} }">
            <core:Icon src="sap-icon://crm-service-manager" color="#0070F2" size="1rem" class="sapUiSmallMarginEnd" />
            <Label text="{i18n>caseLabel}" design="Bold" />
            <ObjectStatus
              text="{state>/caseId}"
              state="Information"
              inverted="true"
              class="sapUiSmallMarginBegin" />
          </HBox>
        </HBox>

        <!-- ═══ Status / warning strips ════════════════════════════════ -->
        <MessageStrip
          id="statusStrip"
          text="{state>/statusMessage}"
          type="{state>/statusState}"
          showIcon="true"
          showCloseButton="true"
          visible="{= !!${state>/statusMessage} }"
          close=".onClearStatus"
          class="sapUiSmallMarginBottom" />

        <MessageStrip
          text="{i18n>noCaseWarning}"
          type="Warning"
          showIcon="true"
          visible="{= !${state>/caseId} }"
          class="sapUiSmallMarginBottom" />

        <!-- ═══ Search & filter panel ══════════════════════════════════ -->
        <Panel expandable="true" expanded="true" headerText="{i18n>filterPanelTitle}">
          <content>
            <l:Grid defaultSpan="XL4 L4 M6 S12" class="sapUiTinyMarginTop sapUiSmallMarginBottom">
              <l:content>

                <!-- Global free-text search -->
                <VBox>
                  <Label text="{i18n>labelSearch}" labelFor="globalSearch" />
                  <SearchField
                    id="globalSearch"
                    placeholder="{i18n>searchPlaceholder}"
                    liveChange=".onLiveSearch"
                    search=".onLiveSearch"
                    showRefreshButton="false"
                    width="100%" />
                </VBox>

                <!-- Ward dropdown -->
                <VBox>
                  <Label text="{i18n>labelWard}" labelFor="filterWard" />
                  <Select id="filterWard" change=".onLiveSearch" width="100%" forceSelection="false">
                    <core:Item key="" text="{i18n>allWards}" />
                  </Select>
                </VBox>

                <!-- Region dropdown -->
                <VBox>
                  <Label text="{i18n>labelRegion}" labelFor="filterRegion" />
                  <Select id="filterRegion" change=".onLiveSearch" width="100%" forceSelection="false">
                    <core:Item key="" text="{i18n>allRegions}" />
                  </Select>
                </VBox>

              </l:content>
            </l:Grid>

            <!-- Filter action row -->
            <HBox justifyContent="End" class="sapUiSmallMarginBottom">
              <Button text="{i18n>btnReset}" icon="sap-icon://clear-filter" press=".onReset" />
              <Button
                text="{i18n>btnSync}"
                icon="sap-icon://synchronize"
                press=".onSync"
                type="Ghost"
                class="sapUiSmallMarginBegin"
                tooltip="{i18n>syncTooltip}" />
            </HBox>
          </content>
        </Panel>

        <!-- ═══ Result count ═══════════════════════════════════════════ -->
        <HBox alignItems="Center" class="sapUiSmallMarginTop sapUiSmallMarginBottom">
          <core:Icon src="sap-icon://list" size="0.875rem" class="sapUiSmallMarginEnd" />
          <Text id="resultCount" text="{i18n>loadingText}" />
          <BusyIndicator id="tableBusy" visible="false" size="0.7rem" class="sapUiSmallMarginBegin" />
        </HBox>

        <!-- ═══ Locations table ════════════════════════════════════════ -->
        <Table
          id="locationsTable"
          items="{results>/results}"
          busy="{results>/busy}"
          growing="true"
          growingThreshold="25"
          growingScrollToLoad="true"
          mode="SingleSelectMaster"
          noDataText="{i18n>noDataText}"
          sticky="ColumnHeaders"
          alternateRowColors="true"
          class="sapUiSmallMarginTop">

          <columns>
            <Column width="35%">
              <Text text="{i18n>colLocationName}" />
            </Column>
            <Column width="15%" minScreenWidth="Tablet" demandPopin="true" popinDisplay="Inline">
              <Text text="{i18n>labelWard}" />
            </Column>
            <Column width="20%" minScreenWidth="Tablet" demandPopin="true" popinDisplay="Inline">
              <Text text="{i18n>labelRegion}" />
            </Column>
            <Column width="15%" minScreenWidth="Desktop" demandPopin="true" popinDisplay="Inline">
              <Text text="{i18n>labelExtension}" />
            </Column>
            <Column width="15%" minScreenWidth="Phone" hAlign="End">
              <Text text="{i18n>labelAction}" />
            </Column>
          </columns>

          <items>
            <ColumnListItem type="Active" press=".onRowPress" highlight="{results>_highlight}">
              <cells>
                <!-- Location name — bold, with subtitle showing full formatted name -->
                <ObjectIdentifier
                  title="{results>LocationName}"
                  text="{results>_fullName}"
                  titleActive="false" />

                <!-- Ward -->
                <ObjectNumber
                  number="{results>Ward}"
                  emphasized="false"
                  unit=""
                  visible="{= !!${results>Ward} }" />

                <!-- Region -->
                <ObjectStatus
                  text="{results>Region}"
                  state="None" />

                <!-- Extension -->
                <ObjectStatus
                  text="{results>Extension}"
                  state="{= ${results>Extension} ? 'Information' : 'None' }"
                  icon="{= ${results>Extension} ? 'sap-icon://tag' : '' }" />

                <!-- Action -->
                <Button
                  text="{i18n>btnUseLocation}"
                  type="Emphasized"
                  icon="sap-icon://accept"
                  press=".onUseLocation"
                  enabled="{= !!${state>/caseId} }"
                  tooltip="{= !${state>/caseId} ? ${i18n>noCaseWarning} : ${i18n>btnUseLocationTooltip} }" />
              </cells>
            </ColumnListItem>
          </items>

        </Table>

      </VBox>
    </content>
  </Page>

</mvc:View>
